{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "1.0",
  "description": "__MSG_ext_description__",
  "default_locale": "en",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}